// prisma/schema.prisma
generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// ইউজার মডেল
model User {
  id           String    @id @default(cuid())
  phone        String    @unique
  name         String
  village      String
  ward         Int
  role         UserRole  @default(USER)
  providerType Category? // ✅ Category enum ব্যবহার করছে
  verified     Boolean   @default(false)
  rating       Float     @default(0)
  otp          String?
  otpExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  services      Service[]
  reports       Report[]
  reportUpvotes ReportUpvote[]
  reviews       Review[]
  notifications Notification[]
  fcmTokens     FCMToken[]
  bookings      Booking[]
  feedback      Feedback[]
}

// সার্ভিস মডেল
model Service {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category
  description String   @db.Text
  hourlyRate  Float
  rating      Float    @default(0)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  reviews  Review[]
  bookings Booking[]

  @@unique([userId]) // ✅ একজন প্রোভাইডার শুধু ১টি সার্ভিস
}

// রিপোর্ট মডেল
model Report {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemType ProblemType
  description String      @db.Text
  imageUrl    String?
  lat         Float?
  lng         Float?
  status      Status      @default(PENDING)
  upVotes     Int         @default(0)
  createdAt   DateTime    @default(now())

  upvotes ReportUpvote[]
}

// রিপোর্ট আপভোট মডেল
model ReportUpvote {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reportId, userId])
}

// রিভিউ মডেল
model Review {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
}

// হাট বাজার মডেল
model Market {
  id         String   @id @default(cuid())
  village    String
  marketDay  String   // সোমবার, মঙ্গলবার, বুধবার etc
  marketTime String
  location   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prices Price[]
}

// পণ্যের দাম মডেল
model Price {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  product   String
  price     Float
  unit      String   @default("কেজি")
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

// নোটিফিকেশন মডেল
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType @default(GENERAL)
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())
}

// FCM টোকেন মডেল
model FCMToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  createdAt DateTime @default(now())
}

// বুকিং মডেল
model Booking {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  date      DateTime
  address   String       @db.Text
  status    BookingStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// ✅ এনাম টাইপ (সব এক জায়গায়)
enum UserRole {
  USER
  PROVIDER
  ADMIN
}

enum Category {
  ELECTRICIAN
  PLUMBER
  MECHANIC
  DOCTOR
  TUTOR
  OTHER
}

enum ProblemType {
  ROAD
  WATER
  ELECTRICITY
  OTHER
}

enum Status {
  PENDING
  PROCESSING
  RESOLVED
}

enum NotificationType {
  GENERAL
  MARKET
  REPORT
  SERVICE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED  // ✅ CANCELLED যোগ করা হয়েছে
}

// ফিডব্যাক মডেল
model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  type      String   @default("TEXT") // TEXT or VOICE
  content   String?
  audioUrl  String?
  rating    Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}