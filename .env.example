# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Auth
JWT_SECRET="change-me"
OTP_EXPIRY_MINUTES=5

# App
NEXTAUTH_URL="http://localhost:3000"

# SMS (Phone OTP)
# - Default: console (OTP prints in server logs; UI shows Dev OTP in development)
# - Production: set SMS_PROVIDER=twilio + the Twilio env vars below
SMS_PROVIDER="console"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

